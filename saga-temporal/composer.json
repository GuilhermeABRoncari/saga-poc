{
    "name": "mobilestock/saga-temporal-poc",
    "description": "PoC de SAGA com Temporal — espelha o saga-rabbitmq",
    "type": "project",
    "require": {
        "php": "^8.3",
        "ext-grpc": "*",
        "temporal/sdk": "^2.17",
        "spiral/roadrunner-cli": "^2.5"
    },
    "autoload": {
        "psr-4": {
            "App\\Sagas\\": "src/Sagas/",
            "App\\Activities\\": "src/Activities/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "spiral/composer-publish-plugin": true
        }
    }
}
